 */

#define PTHREAD_RWLOCK_INITIALIZER _PTHREAD_RWLOCK_INITIALIZER

int	pthread_rwlockattr_init (pthread_rwlockattr_t *__attr);
int	pthread_rwlockattr_destroy (pthread_rwlockattr_t *__attr);
