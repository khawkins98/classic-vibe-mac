#pragma pack(push, 2)


typedef struct ADBDataBlock ADBDataBlock;struct ADBDataBlock {SignedByte devType;SignedByte origADBAddr;ProcPtr dbServiceRtPtr;Ptr dbDataAreaAddr;};

typedef struct ADBSetInfoBlock ADBSetInfoBlock;struct ADBSetInfoBlock {ProcPtr siServiceRtPtr;Ptr siDataAreaAddr;};

// QuickDraw IMV-367 (false);
#define LMGetKbdLast() (*(Byte*)0x0218)
#define LMSetKbdLast(val) (*(Byte*)0x0218 = val)


// QuickDraw IMV-367 (false);
#define LMGetKbdType() (*(Byte*)0x021E)
#define LMSetKbdType(val) (*(Byte*)0x021E = val)


enum { _ADBReInit = 0xA07B };
pascal void ADBReInit() M68K_INLINE(0xA07B);


pascal OSErr ADBOp(Ptr data, ProcPtr procp, Ptr buffer, INTEGER command);


enum { _CountADBs = 0xA077 };
#if TARGET_CPU_68K
#pragma parameter __D0 CountADBs
#endif
pascal INTEGER CountADBs() M68K_INLINE(0xA077);


enum { _GetIndADB = 0xA078 };
#if TARGET_CPU_68K
#pragma parameter __D0 GetIndADB(__A0, __D0)
#endif
pascal OSErr GetIndADB(ADBDataBlock *adbp, INTEGER index) M68K_INLINE(0xA078);


enum { _GetADBInfo = 0xA079 };
#if TARGET_CPU_68K
#pragma parameter __D0 GetADBInfo(__A0, __D0)
#endif
pascal OSErr GetADBInfo(ADBDataBlock *adbp, INTEGER address) M68K_INLINE(0xA079);


enum { _SetADBInfo = 0xA07A };
#if TARGET_CPU_68K
#pragma parameter __D0 SetADBInfo(__A0, __D0)
#endif
pascal OSErr SetADBInfo(ADBSetInfoBlock *adbp, INTEGER address) M68K_INLINE(0xA07A);


#pragma pack(pop)


