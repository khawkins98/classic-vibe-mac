#define LMGethyperlong() (*(LONGINT*)0x01AA)
#define LMSethyperlong(val) (*(LONGINT*)0x01AA = val)


// * NOTE: mathones is a LONGINT that Mathematica looks at that contains -1
//  * on a Mac+
// rsys/misc WHOKNOWS (true-b);
#define LMGetmathones() (*(LONGINT*)0x0282)
#define LMSetmathones(val) (*(LONGINT*)0x0282 = val)


