// FileMgr IMIV-212 (true);
#define LMGetBootDrive() (*(INTEGER*)0x0210)
#define LMSetBootDrive(val) (*(INTEGER*)0x0210 = val)


// FileMgr IMIV-182 (true);
#define LMGetDrvQHdr() (*(QHdr*)0x0308)
#define LMSetDrvQHdr(val) (*(QHdr*)0x0308 = val)


// FileMgr ThinkC (false);
#define LMGetEjectNotify() (*(ProcPtr*)0x0338)
#define LMSetEjectNotify(val) (*(ProcPtr*)0x0338 = val)


// FileMgr IMIV-179 (true);
#define LMGetFCBSPtr() (*(Ptr*)0x034E)
#define LMSetFCBSPtr(val) (*(Ptr*)0x034E = val)


// FileMgr IMIV-178 (true);
#define LMGetDefVCBPtr() (*(VCBPtr*)0x0352)
#define LMSetDefVCBPtr(val) (*(VCBPtr*)0x0352 = val)


// FileMgr IMIV-178 (true);
#define LMGetVCBQHdr() (*(QHdr*)0x0356)
#define LMSetVCBQHdr(val) (*(QHdr*)0x0356 = val)


// FileMgr IMIV-176 (true);
#define LMGetFSQHdr() (*(QHdr*)0x0360)
#define LMSetFSQHdr(val) (*(QHdr*)0x0360 = val)


// FileMgr idunno (true);
#define LMGetWDCBsPtr() (*(Ptr*)0x0372)
#define LMSetWDCBsPtr(val) (*(Ptr*)0x0372 = val)


// FileMgr MPW (true);
#define LMGetDefVRefNum() (*(INTEGER*)0x0384)
#define LMSetDefVRefNum(val) (*(INTEGER*)0x0384 = val)


// * Note: MacLinkPC+ loads 0x358 into a register (i.e. the address of the
//  * pointer to the first element on the VCB queue) and then uses
//  * 72 off of it (0x3A0) and 78 off of it (0x3A6). As long as
//  * there are zeros there, that doesn't hurt us, but normally,
//  * we'd have negative ones in there. Hence we describe them
//  * here and set them to zero in executor.
// const LowMemGlobal<Ptr> FmtDefaults { 0x39E }; // FileMgr ThinkC (false);
// FileMgr IMIV-212 (false);
#define LMGetToExtFS() (*(Ptr*)0x03F2)
#define LMSetToExtFS(val) (*(Ptr*)0x03F2 = val)


// FileMgr IMIV-97 (true);
#define LMGetFSFCBLen() (*(INTEGER*)0x03F6)
#define LMSetFSFCBLen(val) (*(INTEGER*)0x03F6 = val)


