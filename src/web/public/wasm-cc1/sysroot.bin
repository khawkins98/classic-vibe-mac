 *                                 MacTypes.h                                *
 *                                 ==========                                *
 *                                                                           *
 *****************************************************************************/


#pragma pack(push, 2)


typedef int16_t INTEGER;

typedef int32_t LONGINT;

typedef uint32_t ULONGINT;

typedef int8_t Boolean;

// very important not to use this as char
typedef int16_t CharParameter;

typedef int8_t SignedByte;

typedef uint8_t Byte;

typedef char *Ptr;

typedef Ptr *Handle;

typedef int8_t Boolean;

typedef int8_t SInt8;

typedef uint8_t UInt8;

typedef int16_t SInt16;

typedef uint16_t UInt16;

typedef int32_t SInt32;

typedef uint32_t UInt32;

typedef Byte Str15[16];

typedef Byte Str31[32];

typedef Byte Str32[33];

typedef Byte Str63[64];

typedef Byte Str255[256];

typedef Byte *StringPtr;

typedef const uint8_t *ConstStringPtr;

typedef ConstStringPtr ConstStr255Param;

typedef ConstStringPtr ConstStr63Param;

typedef ConstStringPtr ConstStr31Param;

typedef ConstStringPtr ConstStr16Param;

typedef StringPtr *StringHandle;

typedef struct RoutineDescriptor RoutineDescriptor;

typedef RoutineDescriptor *UniversalProcPtr;

typedef pascal void (*VoidProcPtr)();
#if TARGET_API_MAC_CARBON
typedef struct OpaqueVoidProc *VoidUPP;
pascal VoidUPP NewVoidUPP(VoidProcPtr proc);
pascal void DisposeVoidUPP(VoidUPP upp);
#elif TARGET_RT_MAC_CFM
typedef UniversalProcPtr VoidUPP;
enum { uppVoidProcInfo = 0x00000000 };
#define NewVoidUPP(proc) ((VoidUPP)NewRoutineDescriptor((ProcPtr)(proc), uppVoidProcInfo, GetCurrentArchitecture()))
#define DisposeVoidUPP(upp) (DisposeRoutineDescriptor((UniversalProcPtr)(upp)))
#else

typedef VoidProcPtr VoidUPP;
#define NewVoidUPP(proc) (proc)
#define DisposeVoidUPP(proc) do { } while(false)

#endif

#define NewVoidProc(proc) NewVoidUPP(proc)
#define DisposeVoidProc(proc) DisposeVoidUPP(proc)



typedef LONGINT Fixed;

typedef LONGINT Fract;

// SmallFract represnts values between 0 and 65535
typedef uint16_t SmallFract;

enum {MaxSmallFract = 65535,
};

typedef double Extended;

typedef LONGINT Size;

typedef INTEGER OSErr;

typedef LONGINT OSType;

typedef LONGINT ResType;

typedef union QElem QElem;

typedef QElem *QElemPtr;

typedef struct QHdr QHdr;struct QHdr {INTEGER qFlags;QElemPtr qHead;QElemPtr qTail;};

typedef QHdr *QHdrPtr;

enum {noErr = 0,
paramErr = -50,
};

typedef struct Rect Rect;struct Rect {INTEGER top;INTEGER left;INTEGER bottom;INTEGER right;};

typedef Rect *RectPtr;

// from IntlUtil.h
typedef INTEGER ScriptCode;

typedef INTEGER LangCode;

typedef struct Point Point;struct Point {INTEGER v;INTEGER h;};

