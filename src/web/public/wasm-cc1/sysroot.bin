#if __POSIX_VISIBLE >= 199209
__ssp_redirect(size_t, confstr, (int __name, char *__buf, size_t __len), \
    (__name, __buf, __len));
#endif

__ssp_redirect_raw(char *, getcwd, (char *__buf, size_t __len),
    (__buf, __len), __buf != 0, __ssp_bos);

