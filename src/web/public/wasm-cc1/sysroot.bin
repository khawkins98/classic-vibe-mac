// Big-endian 64 bit "comp" data type.  Note that this has a NaN value!
// typedef union {
//     struct
//     {
//         ULONGINT hi;
//         ULONGINT lo;
//     } hilo;
//     signed long long val;
// } comp_t;
typedef struct comp_t comp_t;struct comp_t {int64_t val;};

// "Packed" IEEE 80 bit FP representation (zero field omitted).
typedef struct x80_t x80_t;struct x80_t {uint16_t sgn_and_exp;uint64_t mantissa;};

// For backwards compatibility with old stuff.
typedef x80_t extended80;

typedef comp_t comp;

typedef struct extended96 extended96;struct extended96 {INTEGER exp;INTEGER zero;INTEGER man[4];};

